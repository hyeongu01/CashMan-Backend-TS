{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "paths": {
      "@config/*": ["config/*"],
      "@features/*": ["src/features/*"],
      "@generated/*": ["prisma/generated/*"],
      "@libs/*": ["src/libs/*"],
      "@common/*": ["src/common/*"]
    },
    "rootDir": ".",
    "outDir": "./dist",
    "typeRoots": [
      "./node_modules/@types",
      "./src/common/types"
    ],
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "prisma/generated"]
}